.container { padding: 12px; }
.hero { background: #1e293b; border-radius: 12px; padding: 24px; text-align: center; margin-bottom: 12px; }
.hero-teams { display: flex; justify-content: center; align-items: center; gap: 16px; }
.hero-name { font-size: 20px; font-weight: 800; }
.hero-vs { color: #fbbf24; font-size: 14px; }
.hero-meta { color: #94a3b8; font-size: 13px; margin-top: 8px; display: block; }

.section { background: #1e293b; border-radius: 12px; padding: 16px; margin-bottom: 10px; }
.section-title { font-size: 16px; font-weight: 700; margin-bottom: 12px; display: block; }
.tag { font-size: 11px; padding: 2px 6px; border-radius: 3px; }
.free { background: #4ade80; color: #000; }
.sub-title { font-size: 14px; font-weight: 600; margin: 16px 0 8px; display: block; color: #38bdf8; }

.data-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #334155; }
.label { color: #94a3b8; font-size: 13px; }
.value { font-weight: 600; font-size: 14px; }

.prob-row { display: flex; justify-content: space-around; }
.prob-item { text-align: center; flex: 1; }
.prob-label { font-size: 12px; color: #94a3b8; display: block; }
.prob-val { font-size: 22px; font-weight: 800; display: block; }
.green { color: #4ade80; }
.yellow { color: #fbbf24; }
.orange { color: #fb923c; }
.red { color: #f87171; }

.scores { display: flex; flex-wrap: wrap; gap: 6px; }
.score-item { background: #0f172a; padding: 6px 10px; border-radius: 6px; font-size: 13px; font-weight: 600; }

.lock-box { text-align: center; padding: 24px; }
.lock-icon { font-size: 40px; display: block; }
.lock-text { color: #94a3b8; font-size: 14px; margin: 8px 0 16px; display: block; }
.unlock-btn { background: linear-gradient(135deg, #38bdf8, #818cf8); color: #fff; border: none; border-radius: 8px; padding: 10px 24px; font-size: 15px; font-weight: 600; }
.hint { color: #94a3b8; font-size: 12px; margin-top: 8px; display: block; }
